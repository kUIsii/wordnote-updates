<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:name=".WordNoteApplication"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WordNoteApp">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.AddWordActivity"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.WordDetailActivity"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.CategoryActivity"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.SettingsActivity"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.CalendarViewActivity"
            android:parentActivityName=".ui.SettingsActivity" />

        <activity
            android:name=".ui.DictionaryActivity"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.ChangelogActivity"
            android:parentActivityName=".ui.SettingsActivity" />

        <activity
            android:name=".ui.RecycleBinActivity"
            android:parentActivityName=".ui.SettingsActivity" />

        <activity
            android:name=".ui.StatisticsActivity"
            android:parentActivityName=".ui.SettingsActivity" />

        <activity
            android:name=".ui.QuizSetupActivity"
            android:parentActivityName=".ui.SettingsActivity" />

        <activity
            android:name=".ui.QuizActivity"
            android:parentActivityName=".ui.QuizSetupActivity" />

        <activity
            android:name=".ui.QuizResultActivity"
            android:parentActivityName=".ui.QuizActivity" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
