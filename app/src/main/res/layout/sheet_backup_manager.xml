<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/card_background"
    android:paddingTop="12dp"
    android:maxHeight="560dp">

    <!-- Handle bar -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/sheet_handle_bg" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:text="备份管理"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:text="点击文件可恢复，支持重命名和删除"
        android:textColor="@color/text_hint"
        android:textSize="12sp"
        android:layout_marginBottom="16dp" />

    <!-- New backup button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/newBackupButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="24dp"
        android:text="新建备份"
        android:textSize="14sp"
        app:backgroundTint="@color/primary"
        app:cornerRadius="22dp"
        app:icon="@drawable/ic_backup"
        app:iconGravity="textStart"
        app:iconTint="@color/text_on_primary"
        android:layout_marginBottom="16dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- File list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/backupFileList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:paddingVertical="8dp" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/emptyText"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:gravity="center"
        android:text="暂无备份文件"
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- Cancel button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/cancelButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"
        android:text="关闭"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

</LinearLayout>
